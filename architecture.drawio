        <mxCell id="b3" value="&lt;b style=&apos;font-size:14px&apos;&gt;27 Stock Features&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&apos;font-size:13px&apos;&gt;• Returns (5d–250d)&lt;br&gt;• Volatility (5d, 20d, 120d)&lt;br&gt;• Trend (SMA, RSI)&lt;br&gt;• Z-scores, Drawdown&lt;br&gt;• ATR, H-L ratio&lt;br&gt;• Volume ratio&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;strokeWidth=1.5;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;fontSize=13;arcSize=10;" vertex="1" parent="1">
