        <mxCell id="b6" value="&lt;b style=&apos;font-size:14px&apos;&gt;Hidden Markov Model (HMM)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&apos;font-size:13px&apos;&gt;• Gaussian HMM on 8 index features&lt;br&gt;• BIC-based model selection → 2 regimes&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;strokeWidth=1.5;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;fontSize=13;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="55" width="420" height="85" as="geometry"/>
        </mxCell>

        <mxCell id="b7" value="&lt;b style=&apos;font-size:15px;color:#2E7D32&apos;&gt;Bull Market&lt;/b&gt;&lt;br&gt;&lt;b style=&apos;font-size:13px&apos;&gt;(72.5% of days)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&apos;font-size:13px&apos;&gt;• Low volatility (~15%)&lt;br&gt;• Persistence: 99.4%&lt;br&gt;• Calm, trending up&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=1.5;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;fontSize=13;arcSize=10;" vertex="1" parent="1">
